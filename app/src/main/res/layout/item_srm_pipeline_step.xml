<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="14dp"
    android:background="@drawable/bg_card" android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <View android:id="@+id/viewPipelineIndicator"
        android:layout_width="32dp" android:layout_height="32dp"
        android:background="@drawable/bg_step_pending"
        android:layout_marginEnd="12dp"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tvPipelineNum"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1" android:textColor="#E8EDF5"
                android:textStyle="bold" android:textSize="13sp" android:layout_marginEnd="6dp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tvPipelineLabel"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Level" android:textColor="#E8EDF5"
                android:textStyle="bold" android:textSize="13sp"/>
        </LinearLayout>
        <TextView android:id="@+id/tvPipelineNote"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textColor="#7B94B5"
            android:textSize="11sp" android:visibility="gone" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvPipelineBadge"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="PENDING" android:textColor="#9E9E9E"
        android:textSize="10sp" android:textStyle="bold"/>
</LinearLayout>
