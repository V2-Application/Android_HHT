<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/store_grt_button_bar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- GRT SOURCE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="GRT SOURCE"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_grt_section_card"
                android:orientation="horizontal"
                android:padding="6dp"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/store_grt_source_0001"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_grt_source_selected"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GRT from 0001"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Main warehouse"
                        android:textColor="@color/textSecondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/store_grt_source_0006"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_grt_source_unselected"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GRT from 0006"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Secondary warehouse"
                        android:textColor="@color/textSecondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

              <!-- Scan Mode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="12">

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="5" />

                <RadioGroup
                    android:id="@+id/store_grt_scan_mode_group"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/store_grt_scan_mode_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:minHeight="32dp"
                        android:paddingEnd="16dp"
                        android:text="ALL"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/store_grt_scan_mode_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="32dp"
                        android:text="SIZE"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp" />
                </RadioGroup>
            </LinearLayout>

            <!-- Picklist No. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:text="Picklist No."
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/bg_dropdown_box">

                    <Spinner
                        android:id="@+id/store_grt_picklist_no"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Scan External HU -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:text="Scan External HU"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/store_grt_external_hu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/border"
                    android:hint="scan by HHT..."
                    android:imeOptions="actionDone"
                    android:maxLines="1"
                    android:minHeight="36dp"
                    android:padding="6dp"
                    android:singleLine="true"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Plant -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:text="Plant"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/store_grt_fdes_plant"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/border_disabled_input"
                    android:enabled="false"
                    android:hint="auto-filled..."
                    android:maxLines="1"
                    android:minHeight="36dp"
                    android:padding="6dp"
                    android:singleLine="true"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Article -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:text="Article"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/store_grt_article"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/border"
                    android:hint="scan article..."
                    android:imeOptions="actionDone"
                    android:maxLines="1"
                    android:minHeight="36dp"
                    android:padding="6dp"
                    android:singleLine="true"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Scan QTY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:text="Scan QTY"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/store_grt_scan_qty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/border_disabled_input"
                    android:enabled="false"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:minHeight="36dp"
                    android:padding="6dp"
                    android:singleLine="true"
                    android:text="0"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Packing Material -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:text="Packing Material"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/bg_dropdown_box">

                    <Spinner
                        android:id="@+id/store_grt_packing_material"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp" />
                </RelativeLayout>
            </LinearLayout>

          
        </LinearLayout>
    </ScrollView>

    <!-- Bottom buttons -->
    <LinearLayout
        android:id="@+id/store_grt_button_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/bgCard"
        android:orientation="horizontal"
        android:padding="8dp"
        android:weightSum="3">

        <Button
            android:id="@+id/store_grt_btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/shadow"
            android:text="BACK"
            android:textColor="@color/textPrimary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/store_grt_btn_reset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/shadow"
            android:text="RESET"
            android:textColor="@color/textPrimary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/store_grt_btn_submit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/shadow"
            android:text="SAVE"
            android:textColor="@color/textPrimary"
            android:textSize="14sp" />
    </LinearLayout>
</RelativeLayout>
