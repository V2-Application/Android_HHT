<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1F33">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="4dp">
        <TextView android:layout_width="32dp" android:layout_height="32dp"
            android:text="V2" android:textColor="#FFFFFF" android:textStyle="bold"
            android:textSize="13sp" android:gravity="center"
            android:background="@drawable/bg_v2_badge" android:layout_marginEnd="10dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvMdmWelcome"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MDM Team" android:textColor="#E8EDF5"
                android:textStyle="bold" android:textSize="15sp"/>
            <TextView android:id="@+id/tvMdmSapStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Checking SAP…" android:textColor="#5A6A8A" android:textSize="11sp"/>
        </LinearLayout>
        <Button android:id="@+id/btnMdmLogout"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="Logout" android:textSize="11sp" android:textColor="#EF9A9A"
            android:background="@drawable/bg_btn_outline_red" android:paddingStart="10dp"
            android:paddingEnd="10dp"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressMdmDash"
        android:layout_width="match_parent" android:layout_height="3dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true" android:progressTint="#F97316"
        android:visibility="gone"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Stats -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#1A1206" android:padding="12dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SAP QUEUE" android:textColor="#5A6A8A" android:textSize="9sp"/>
                    <TextView android:id="@+id/tvMdmSapQueue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#F97316"
                        android:textStyle="bold" android:textSize="24sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_green" android:padding="12dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CREATED" android:textColor="#5A6A8A" android:textSize="9sp"/>
                    <TextView android:id="@+id/tvMdmCreated"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#22C55E"
                        android:textStyle="bold" android:textSize="24sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_blue" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TOTAL" android:textColor="#5A6A8A" android:textSize="9sp"/>
                    <TextView android:id="@+id/tvMdmTotal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#3B82F6"
                        android:textStyle="bold" android:textSize="24sp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SAP CREATION QUEUE" android:textColor="#5A6A8A"
                android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tvMdmEmptyQueue"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="✅  SAP queue is empty. No vendors pending."
                android:textColor="#66BB6A" android:background="#0A2A1A"
                android:padding="14dp" android:textSize="13sp"
                android:visibility="gone" android:layout_marginBottom="8dp"/>

            <ListView android:id="@+id/lvMdmQueue"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:divider="@null" android:dividerHeight="0dp" android:scrollbars="none"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
