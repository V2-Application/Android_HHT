<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Scan field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SCAN HU BARCODE"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/textSecondary"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/text_outward_hu_weight_scan_hu"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Scan or enter HU number"
        android:inputType="textCapCharacters"
        android:imeOptions="actionDone"
        android:textSize="16sp"
        android:textColor="@color/textPrimary"
        android:textColorHint="@color/textHint"
        android:background="@color/bgInput"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Result card (hidden until scanned) -->
    <LinearLayout
        android:id="@+id/ll_outward_hu_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bgCard"
        android:padding="16dp"
        android:elevation="2dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <!-- HU number -->
        <TextView
            android:id="@+id/text_outward_hu_weight_scanned_hu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginBottom="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="12dp" />

        <!-- Budget weight row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Budget Weight"
                android:textSize="13sp" android:textColor="@color/textSecondary" />
            <TextView
                android:id="@+id/text_outward_hu_weight_budget_weight"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/textPrimary" />
        </LinearLayout>

        <!-- Actual weight row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Actual Weight"
                android:textSize="13sp" android:textColor="@color/textSecondary" />
            <TextView
                android:id="@+id/text_outward_hu_weight_actual_weight"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/textPrimary" />
        </LinearLayout>

        <!-- Variance row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Variance"
                android:textSize="13sp" android:textColor="@color/textSecondary" />
            <TextView
                android:id="@+id/text_outward_hu_weight_variance"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="—" android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/v2Blue" />
        </LinearLayout>
    </LinearLayout>

    <!-- Save button -->
    <Button
        android:id="@+id/button_outward_hu_weight_save"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="SAVE"
        android:textColor="@color/textOnPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@color/v2Blue"
        android:visibility="gone" />

</LinearLayout>
