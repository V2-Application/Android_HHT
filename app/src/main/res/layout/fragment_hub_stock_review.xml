<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HU Stock Review"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="#e71821"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Plant (read-only, auto-filled) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plant (WERKS)"
            android:textStyle="bold"
            android:textColor="#333"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <EditText
            android:id="@+id/txt_hub_stock_review_werks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:background="#e0e0e0"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="#555"
            android:layout_marginBottom="12dp"
            android:hint="Auto-filled from device"/>

        <!-- HU Number -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Handling Unit (IV_HU) *"
            android:textStyle="bold"
            android:textColor="#333"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <EditText
            android:id="@+id/txt_hub_stock_review_hu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Scan or enter HU number"
            android:inputType="textCapCharacters|textNoSuggestions"
            android:imeOptions="actionNext"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <!-- Storage Type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Storage Type (IV_LGTYP) *"
            android:textStyle="bold"
            android:textColor="#333"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <EditText
            android:id="@+id/txt_hub_stock_review_lgtyp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter storage type (e.g. 001)"
            android:inputType="textCapCharacters|textNoSuggestions"
            android:imeOptions="actionDone"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_hub_stock_review_check"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CHECK STOCK"
                android:background="#e71821"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_hub_stock_review_clear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CLEAR"
                android:background="#757575"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Result Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SAP Response"
                android:textStyle="bold"
                android:textColor="#555"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/txt_hub_stock_review_result_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/txt_hub_stock_review_result_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#222"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
