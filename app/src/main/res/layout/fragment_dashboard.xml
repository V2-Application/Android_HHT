<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:tag="home_tag">

            <!-- Section: DC Operations -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DC OPERATIONS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/inbound"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="INWARD"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@color/v2Blue" />

                <Button
                    android:id="@+id/outbound"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="OUTWARD"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@color/v2Blue" />
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/stock_take"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="STOCK TAKE"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@color/v2Blue" />

                <Button
                    android:id="@+id/stock_take2"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="STOCK TAKE V2"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@color/v2Blue" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginVertical="10dp" />

            <!-- Section: Store Apps -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STORE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/retailApp"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="RETAIL APP"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@color/v2Blue" />

                <Button
                    android:id="@+id/store_ecomm"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="E-COMM"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@color/v2Blue" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginVertical="10dp" />

            <!-- Section: Utilities -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UTILITIES"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/Rf_idScanner"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="RFID Scanner"
                android:textColor="@color/textOnPrimary"
                android:textSize="13sp"
                android:background="@color/v2Blue"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/picklist_save"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Picklist"
                android:textColor="@color/textOnPrimary"
                android:textSize="13sp"
                android:background="@color/v2Blue"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
