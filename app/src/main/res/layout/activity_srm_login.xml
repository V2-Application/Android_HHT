<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0F1F33" android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <!-- Logo + Brand -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            <TextView
                android:layout_width="48dp" android:layout_height="48dp"
                android:text="V2" android:textColor="#FFFFFF" android:textStyle="bold"
                android:textSize="18sp" android:gravity="center"
                android:background="@drawable/bg_v2_badge" android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SRM PORTAL" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="16sp" android:letterSpacing="0.08"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="V2 Retail Limited" android:textColor="#7B94B5"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Headline -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Welcome Back" android:textColor="#E8EDF5"
            android:textSize="26sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Sign in to access your portal" android:textColor="#7B94B5"
            android:textSize="13sp" android:layout_marginBottom="24dp"/>

        <!-- Role selector label -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SELECT YOUR ROLE" android:textColor="#5A6A8A"
            android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>

        <!-- Role spinner -->
        <Spinner android:id="@+id/spinnerSrmRole"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/bg_field" android:paddingStart="14dp"
            android:paddingEnd="14dp" android:layout_marginBottom="16dp"
            android:spinnerMode="dropdown"/>

        <!-- Username -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="USERNAME / EMAIL" android:textColor="#5A6A8A"
            android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etSrmUsername"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/bg_field"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:textColor="#E8EDF5" android:textColorHint="#5A6A8A"
            android:hint="Enter username or email"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="14dp"/>

        <!-- Password -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PASSWORD" android:textColor="#5A6A8A"
            android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etSrmPassword"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/bg_field"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:textColor="#E8EDF5" android:textColorHint="#5A6A8A"
            android:hint="••••••••"
            android:inputType="textPassword"
            android:layout_marginBottom="10dp"/>

        <!-- Error -->
        <TextView android:id="@+id/tvSrmLoginError"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_error_card"
            android:padding="10dp" android:textColor="#EF9A9A"
            android:textSize="12sp" android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Login button -->
        <Button android:id="@+id/btnSrmLogin"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="SIGN IN" android:textColor="#FFFFFF"
            android:textStyle="bold" android:textSize="14sp"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginTop="4dp"/>

        <ProgressBar android:id="@+id/progressSrmLogin"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:visibility="gone"
            android:layout_marginTop="12dp"/>

        <!-- Demo creds hint -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="14dp" android:layout_marginTop="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DEMO CREDENTIALS" android:textColor="#5A6A8A"
                android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#7B94B5" android:textSize="11sp" android:lineSpacingMultiplier="1.4"
                android:text="vendor / vendor123\nadmin / admin123\nsubdiv / sub123\ndivhead / div123\nfinance / fin123\npocomm / po123\nmdm / mdm123"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
