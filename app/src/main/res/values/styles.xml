<resources>
    <style name="AppFullScreenTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/v2Blue</item>
        <item name="colorPrimaryDark">@color/v2BlueDark</item>
        <item name="colorAccent">@color/v2Red</item>
        <item name="android:windowBackground">@color/bgPage</item>
    </style>
    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="AppTheme.PopupOverlay"  parent="ThemeOverlay.AppCompat.Light" />
    <style name="AppTheme.Launcher">
        <item name="android:windowBackground">@drawable/launch_screen</item>
    </style>
    <style name="myDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- ── Base button (explicit parent prevents inheritance error) ── -->
    <style name="BtnBase" parent="Widget.AppCompat.Button">
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Primary: V2 Blue -->
    <style name="BtnPrimary" parent="BtnBase">
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/textOnPrimary</item>
    </style>

    <!-- Secondary: V2 Red -->
    <style name="BtnSecondary" parent="BtnBase">
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:textColor">@color/textOnPrimary</item>
    </style>

    <!-- Ghost: outlined, for Back/Cancel -->
    <style name="BtnGhost" parent="BtnBase">
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/btn_ghost</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Muted: for disabled / in-progress items -->
    <style name="BtnMuted" parent="BtnBase">
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/btn_muted</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- ── Section label ───────────────────────────────── -->
    <style name="SectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>
</resources>
