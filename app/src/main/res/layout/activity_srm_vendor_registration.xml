<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1F33">

    <!-- Topbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="4dp">
        <Button android:id="@+id/btnSrmRegBack"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Back" android:textSize="12sp" android:textColor="#7B94B5"
            android:background="@drawable/bg_btn_ghost"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvSrmRegStepTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Vendor Details" android:textColor="#E8EDF5"
                android:textStyle="bold" android:textSize="15sp"/>
            <TextView android:id="@+id/tvSrmRegStepCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1 / 5" android:textColor="#5A6A8A" android:textSize="11sp"/>
        </LinearLayout>
        <Button android:id="@+id/btnSrmRegNext"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Next →" android:textSize="12sp" android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary_sm"/>
    </LinearLayout>

    <!-- Step progress bar -->
    <ProgressBar android:id="@+id/progressSrmRegStep"
        android:layout_width="match_parent" android:layout_height="4dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:progressTint="#3B82F6" android:progressBackgroundTint="#1C2E44"
        android:progress="20" android:max="100"/>

    <!-- Step content scroll -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- STEP 0: Vendor Details -->
            <LinearLayout android:id="@+id/layoutSrmStep0"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VENDOR TYPE" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSrmVendorType"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BUSINESS TYPE" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSrmBusinessType"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VENDOR RELATION" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSrmVendorRelation"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="COMPANY CODE *" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSrmCompanyCode"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DIVISION / SECTION *" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSrmDivision"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VENDOR NAME *" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etSrmVendorName"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:paddingStart="14dp"
                    android:paddingEnd="14dp" android:textColor="#E8EDF5"
                    android:textColorHint="#5A6A8A" android:hint="Full company name"
                    android:inputType="textCapCharacters" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CONTACT PERSON *" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etSrmContactPerson"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:paddingStart="14dp"
                    android:paddingEnd="14dp" android:textColor="#E8EDF5"
                    android:textColorHint="#5A6A8A" android:hint="Authorised contact person"
                    android:inputType="textPersonName|textCapWords" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MAILING ADDRESS" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etSrmAddress"
                    android:layout_width="match_parent" android:layout_height="80dp"
                    android:background="@drawable/bg_field" android:paddingStart="14dp"
                    android:paddingEnd="14dp" android:paddingTop="10dp"
                    android:textColor="#E8EDF5" android:textColorHint="#5A6A8A"
                    android:hint="Complete mailing address" android:gravity="top"
                    android:inputType="textMultiLine" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CITY *" android:textColor="#5A6A8A" android:textSize="10sp"
                            android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etSrmCity"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/bg_field" android:paddingStart="14dp"
                            android:paddingEnd="14dp" android:textColor="#E8EDF5"
                            android:textColorHint="#5A6A8A" android:hint="City"
                            android:inputType="textCapWords"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="STATE *" android:textColor="#5A6A8A" android:textSize="10sp"
                            android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                        <Spinner android:id="@+id/spSrmState"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/bg_field"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="MOBILE *" android:textColor="#5A6A8A" android:textSize="10sp"
                            android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etSrmMobile"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/bg_field" android:paddingStart="14dp"
                            android:paddingEnd="14dp" android:textColor="#E8EDF5"
                            android:textColorHint="#5A6A8A" android:hint="10-digit mobile"
                            android:inputType="phone" android:maxLength="10"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="EMAIL" android:textColor="#5A6A8A" android:textSize="10sp"
                            android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etSrmEmail"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/bg_field" android:paddingStart="14dp"
                            android:paddingEnd="14dp" android:textColor="#E8EDF5"
                            android:textColorHint="#5A6A8A" android:hint="email@company.com"
                            android:inputType="textEmailAddress"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- STEP 1: Banking -->
            <LinearLayout android:id="@+id/layoutSrmStep1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">
                <include layout="@layout/partial_srm_banking_fields"/>
            </LinearLayout>

            <!-- STEP 2: Buying -->
            <LinearLayout android:id="@+id/layoutSrmStep2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">
                <include layout="@layout/partial_srm_buying_fields"/>
            </LinearLayout>

            <!-- STEP 3: Documents -->
            <LinearLayout android:id="@+id/layoutSrmStep3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="All 4 documents are MANDATORY" android:textColor="#FCD34D"
                    android:background="#1A2800" android:padding="12dp"
                    android:textSize="13sp" android:layout_marginBottom="16dp"/>

                <!-- PAN Card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📄" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="PAN Card" android:textColor="#E8EDF5"
                                android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="MANDATORY" android:textColor="#EF9A9A" android:textSize="10sp"/>
                        </LinearLayout>
                        <Button android:id="@+id/btnSrmDoc0"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Upload" android:textSize="12sp" android:textColor="#FFFFFF"
                            android:background="@drawable/bg_btn_primary_sm"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvSrmDoc0Status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Not uploaded" android:textColor="#5A6A8A"
                        android:textSize="12sp" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Cancelled Cheque -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏦" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cancelled Cheque" android:textColor="#E8EDF5"
                                android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="MANDATORY" android:textColor="#EF9A9A" android:textSize="10sp"/>
                        </LinearLayout>
                        <Button android:id="@+id/btnSrmDoc1"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Upload" android:textSize="12sp" android:textColor="#FFFFFF"
                            android:background="@drawable/bg_btn_primary_sm"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvSrmDoc1Status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Not uploaded" android:textColor="#5A6A8A"
                        android:textSize="12sp" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- GST Certificate -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📑" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="GST Certificate" android:textColor="#E8EDF5"
                                android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="MANDATORY" android:textColor="#EF9A9A" android:textSize="10sp"/>
                        </LinearLayout>
                        <Button android:id="@+id/btnSrmDoc2"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Upload" android:textSize="12sp" android:textColor="#FFFFFF"
                            android:background="@drawable/bg_btn_primary_sm"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvSrmDoc2Status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Not uploaded" android:textColor="#5A6A8A"
                        android:textSize="12sp" android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Bill Copy -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card"
                    android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🧾" android:textSize="22sp" android:layout_marginEnd="10dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Bill Copy" android:textColor="#E8EDF5"
                                android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="MANDATORY" android:textColor="#EF9A9A" android:textSize="10sp"/>
                        </LinearLayout>
                        <Button android:id="@+id/btnSrmDoc3"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Upload" android:textSize="12sp" android:textColor="#FFFFFF"
                            android:background="@drawable/bg_btn_primary_sm"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvSrmDoc3Status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Not uploaded" android:textColor="#5A6A8A"
                        android:textSize="12sp" android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- STEP 4: Review -->
            <LinearLayout android:id="@+id/layoutSrmStep4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="ℹ  Review your details before submitting." android:textColor="#93C5FD"
                    android:background="#0A1E3A" android:padding="12dp"
                    android:textSize="13sp" android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card"
                    android:padding="16dp" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="APPLICATION SUMMARY" android:textColor="#5A6A8A"
                        android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>
                    <include layout="@layout/partial_srm_review_fields"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="DOCUMENTS" android:textColor="#5A6A8A"
                        android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvSrmReviewDocs"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#E8EDF5"
                        android:textSize="13sp" android:lineSpacingMultiplier="1.6"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Submit progress -->
    <ProgressBar android:id="@+id/progressSrmRegSubmit"
        android:layout_width="match_parent" android:layout_height="4dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true" android:progressTint="#22C55E"
        android:visibility="gone"/>
</LinearLayout>
