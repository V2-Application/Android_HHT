<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1F33">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="4dp">
        <TextView android:layout_width="32dp" android:layout_height="32dp"
            android:text="V2" android:textColor="#FFFFFF" android:textStyle="bold"
            android:textSize="13sp" android:gravity="center"
            android:background="@drawable/bg_v2_badge" android:layout_marginEnd="10dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="My Documents"
            android:textColor="#E8EDF5" android:textStyle="bold" android:textSize="16sp"/>
    </LinearLayout>
    <ProgressBar android:id="@+id/progressSrmMyDocs"
        android:layout_width="match_parent" android:layout_height="3dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true" android:progressTint="#3B82F6"
        android:visibility="gone"/>
    <TextView android:id="@+id/tvSrmMyDocsNoApp"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="No active application found. Please complete registration first."
        android:textColor="#F59E0B" android:background="#1A1206" android:padding="14dp"
        android:textSize="13sp" android:visibility="gone"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:id="@+id/llSrmDocContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp"/>
    </ScrollView>
</LinearLayout>
