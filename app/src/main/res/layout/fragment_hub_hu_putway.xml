<?xml version="1.0" encoding="utf-8"?>
<!--
  HUB HU Putway — RFC: ZWM_HUB_HU_PUTWAY_RFC
  UI redesign 2026-04-24: inline "label left, input right" rows inside a
  bordered card, matching the user's sketch.
  Inputs:
    Plant        (IV_WERKS)     — readonly, auto-filled from SharedPreferences
    Crate HU     (IV_CRATE_HU)  — scannable, advances to BIN
    BIN          (IV_BIN)       — scannable, advances to Storage Type
    Storage Type (IV_LGTYP)     — scannable, auto-submits the RFC
  Output: ES_RETURN {TYPE, MESSAGE} shown in result panel below the form.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Bordered card containing the 4 input rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/form_section_border"
            android:padding="14dp">

            <!-- Plant (readonly, auto-filled) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Plant"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <EditText
                    android:id="@+id/txt_hub_putway_werks"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Plant"
                    android:textSize="16sp"
                    android:textColor="#555555"
                    android:background="#EEEEEE"
                    android:padding="8dp"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false" />
            </LinearLayout>

            <!-- Crate HU (scannable) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Crate HU"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <EditText
                    android:id="@+id/txt_hub_putway_crate_hu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Scan / Enter Crate HU"
                    android:textSize="16sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionNext"
                    android:padding="8dp"
                    android:background="@android:drawable/edit_text" />
            </LinearLayout>

            <!-- BIN (scannable) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="BIN"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <EditText
                    android:id="@+id/txt_hub_putway_bin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Scan / Enter BIN"
                    android:textSize="16sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionNext"
                    android:padding="8dp"
                    android:background="@android:drawable/edit_text" />
            </LinearLayout>

            <!-- Storage Type (scannable, triggers submit) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Storage Type"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <EditText
                    android:id="@+id/txt_hub_putway_lgtyp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="e.g. V11"
                    android:textSize="16sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionDone"
                    android:padding="8dp"
                    android:background="@android:drawable/edit_text" />
            </LinearLayout>

        </LinearLayout>

        <!-- Result panel — hidden until first response -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txt_hub_putway_result_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txt_hub_putway_result_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:padding="4dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
