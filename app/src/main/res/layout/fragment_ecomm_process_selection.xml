<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.v2retail.dotvik.ecomm.Ecomm_Process_Selection">

    <!-- TODO: Update blank fragment layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="@color/bgPage"
        android:padding="5dp">

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"

            android:id="@+id/picking"
            android:background="@color/v2Blue"
            android:text="MSA Picking" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Putwall"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"

            android:id="@+id/putwall"
            android:background="@color/v2Blue" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Packing"

            android:id="@+id/packing"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:background="@color/v2Blue" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLA"

            android:id="@+id/cla"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:background="@color/v2Blue" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel QC Putaway"

            android:id="@+id/cancelqcputaway"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:background="@color/v2Blue" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Putaway Crate To MSA Bin"

            android:id="@+id/putawaycratetomsabin"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:background="@color/v2Blue" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Store Order Reject"

            android:id="@+id/storeorderreject"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:background="@color/v2Blue" />
    </LinearLayout>

</FrameLayout>