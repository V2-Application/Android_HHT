<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OUTWARD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/picking"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_secondary"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="Picking" />
                <Button
                    android:id="@+id/Hu_Scan"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_secondary"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="HU Scan" />
            </LinearLayout>
            <Button
                android:id="@+id/paperless_picking"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Paperless Picking" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/tvs_paperless_picking"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_secondary"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="TVS Paperless Picking" />
                <Button
                    android:id="@+id/tvs_paperless_picking_live_hu"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_secondary"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="Live HU TVS Paperless" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/empty_bin"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_secondary"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="Empty Bin" />
                <Button
                    android:id="@+id/grt_hu_move"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_secondary"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="GRT HU Move" />
            </LinearLayout>
            <Button
                android:id="@+id/shade_stock_movement"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Shade Stock Movement" />
            <Button
                android:id="@+id/outward_hu_weight"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="HU Weight" />
            <Button
                android:id="@+id/hu_swap_print"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_primary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="HU Swap Print" />
            <Button
                android:id="@+id/dc_grt"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_muted"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="DC GRT" />
            <Button
                android:id="@+id/hu_move_cla"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_muted"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="HU Move To CLA" />
            <Button
                android:id="@+id/stock_movement"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_muted"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Sample Stock Movement" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
