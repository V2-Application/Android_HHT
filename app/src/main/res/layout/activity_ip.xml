<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Logo / brand block -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="V2"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@color/v2Blue"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Warehouse Operations"
            android:textSize="13sp"
            android:textColor="@color/textSecondary"
            android:letterSpacing="0.08"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bgCard"
        android:padding="20dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Server"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/textSecondary"
            android:letterSpacing="0.06"
            android:layout_marginBottom="10dp" />

        <!-- Server spinner -->
        <Spinner
            android:id="@+id/address_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bgInput"
            android:padding="10dp"
            android:layout_marginBottom="16dp" />

        <!-- App version chip -->
        <TextView
            android:id="@+id/tv_apk_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v12.106"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:layout_marginBottom="20dp" />

        <!-- Connect button -->
        <Button
            android:id="@+id/connect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CONNECT"
            android:textColor="@color/textOnPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@color/v2Blue"
            android:layout_marginBottom="10dp" />

        <!-- Exit button -->
        <Button
            android:id="@+id/exit"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Exit"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:background="@color/bgInput" />
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="V2 Retail Ltd · WMS"
        android:textSize="11sp"
        android:textColor="@color/textHint"
        android:layout_marginTop="32dp" />

</LinearLayout>
