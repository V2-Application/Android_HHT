<?xml version="1.0" encoding="utf-8"?>
<!--
  HUB HU Picking — RFC: ZWM_HUB_HU_PICKING_RFC
  Inputs:
    Plant   (IV_WERKS)  — readonly, from SharedPreferences
    Store   (IV_STORE)  — scannable
    BIN     (IV_BIN)    — scannable, triggers auto-submit
  Output: ES_RETURN {TYPE, MESSAGE} → shown in result panel
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Plant (WERKS) — readonly, greyed -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plant"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/txt_hub_picking_werks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Plant"
            android:textSize="16sp"
            android:textColor="#555555"
            android:background="#E0E0E0"
            android:padding="10dp"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <!-- Store (IV_STORE) — scannable -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Store"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/txt_hub_picking_store"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Scan / Enter Store"
            android:textSize="16sp"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionNext"
            android:padding="10dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <!-- BIN (IV_BIN) — scannable; triggers submit -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BIN"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/txt_hub_picking_bin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Scan / Enter BIN"
            android:textSize="16sp"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:padding="10dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Result panel — TYPE + MESSAGE from ES_RETURN (hidden until response) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txt_hub_picking_result_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txt_hub_picking_result_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:padding="4dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
