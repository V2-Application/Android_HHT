<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1F33">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="4dp">
        <TextView android:layout_width="32dp" android:layout_height="32dp"
            android:text="V2" android:textColor="#FFFFFF" android:textStyle="bold"
            android:textSize="13sp" android:gravity="center"
            android:background="@drawable/bg_v2_badge" android:layout_marginEnd="10dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Admin Dashboard"
            android:textColor="#E8EDF5" android:textStyle="bold" android:textSize="16sp"/>
        <Button android:id="@+id/btnAdminRefresh"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="↻" android:textSize="16sp" android:textColor="#7B94B5"
            android:background="@drawable/bg_btn_ghost" android:layout_marginEnd="6dp"/>
        <Button android:id="@+id/btnAdminLogout"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="Logout" android:textSize="11sp" android:textColor="#EF9A9A"
            android:background="@drawable/bg_btn_outline_red" android:paddingStart="10dp"
            android:paddingEnd="10dp"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressAdminDash"
        android:layout_width="match_parent" android:layout_height="3dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true" android:progressTint="#3B82F6"
        android:visibility="gone"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <!-- Stats grid -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_stat_card_blue" android:padding="10dp" android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TOTAL" android:textColor="#5A6A8A" android:textSize="9sp"/>
                <TextView android:id="@+id/tvAdminTotal" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#3B82F6" android:textStyle="bold" android:textSize="20sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#120E06" android:padding="10dp" android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PIPELINE" android:textColor="#5A6A8A" android:textSize="9sp"/>
                <TextView android:id="@+id/tvAdminPipeline" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#F59E0B" android:textStyle="bold" android:textSize="20sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/bg_stat_card_green" android:padding="10dp" android:layout_marginEnd="5dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SAP DONE" android:textColor="#5A6A8A" android:textSize="9sp"/>
                <TextView android:id="@+id/tvAdminCreated" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#22C55E" android:textStyle="bold" android:textSize="20sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#1A0A0A" android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="REJECTED" android:textColor="#5A6A8A" android:textSize="9sp"/>
                <TextView android:id="@+id/tvAdminRejected" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#EF4444" android:textStyle="bold" android:textSize="20sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Sub-stats -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="horizontal"
                android:background="@drawable/bg_card" android:padding="8dp"
                android:gravity="center_vertical" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="L1: " android:textColor="#5A6A8A" android:textSize="11sp"/>
                <TextView android:id="@+id/tvAdminL1" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#F59E0B" android:textStyle="bold" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="horizontal"
                android:background="@drawable/bg_card" android:padding="8dp"
                android:gravity="center_vertical" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="L2: " android:textColor="#5A6A8A" android:textSize="11sp"/>
                <TextView android:id="@+id/tvAdminL2" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#A855F7" android:textStyle="bold" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="horizontal"
                android:background="@drawable/bg_card" android:padding="8dp"
                android:gravity="center_vertical" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="L3: " android:textColor="#5A6A8A" android:textSize="11sp"/>
                <TextView android:id="@+id/tvAdminL3" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#06B6D4" android:textStyle="bold" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="horizontal"
                android:background="@drawable/bg_card" android:padding="8dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SAP: " android:textColor="#5A6A8A" android:textSize="11sp"/>
                <TextView android:id="@+id/tvAdminL5" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="#F97316" android:textStyle="bold" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Search + Filter -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <EditText android:id="@+id/etAdminSearch"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:background="@drawable/bg_field"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:textColor="#E8EDF5" android:textColorHint="#5A6A8A"
                android:hint="Search vendor / ticket…"
                android:inputType="text" android:layout_marginEnd="8dp"/>
            <Spinner android:id="@+id/spAdminFilter"
                android:layout_width="130dp" android:layout_height="44dp"
                android:background="@drawable/bg_field"/>
        </LinearLayout>

    </LinearLayout>

    <ListView android:id="@+id/lvAdminApps"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:divider="@null"
        android:dividerHeight="0dp" android:paddingStart="14dp"
        android:paddingEnd="14dp" android:clipToPadding="false"/>

</LinearLayout>
