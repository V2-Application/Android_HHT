<resources>
    <!-- App themes -->
    <style name="AppFullScreenTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/v2Blue</item>
        <item name="colorPrimaryDark">@color/v2BlueDark</item>
        <item name="colorAccent">@color/v2Blue</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <!-- ── V2 WMS Design System ─────────────────────────── -->

    <!-- Cards -->
    <style name="WMS.Card">
        <item name="android:background">@color/bgCard</item>
        <item name="android:padding">16dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Buttons -->
    <style name="WMS.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textColor">@color/textOnPrimary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:background">@color/v2Blue</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="WMS.Button.Red">
        <item name="android:background">@color/v2Red</item>
    </style>

    <style name="WMS.Button.Ghost">
        <item name="android:background">@color/bgInput</item>
        <item name="android:textColor">@color/textSecondary</item>
    </style>

    <style name="WMS.Button.Small">
        <item name="android:layout_height">44dp</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Inputs -->
    <style name="WMS.Input">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@color/bgInput</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textColorHint">@color/textHint</item>
        <item name="android:imeOptions">actionDone</item>
        <item name="android:inputType">textCapCharacters|textNoSuggestions</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <!-- Text styles -->
    <style name="WMS.Label">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="WMS.SectionHeader">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:layout_marginStart">4dp</item>
    </style>

    <style name="WMS.CounterText">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/v2Blue</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="WMS.StatusText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/successText</item>
        <item name="android:padding">6dp</item>
    </style>

    <!-- Stat cards (for dashboard) -->
    <style name="WMS.StatCard">
        <item name="android:background">@color/bgCard</item>
        <item name="android:padding">14dp</item>
        <item name="android:elevation">1dp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <!-- Badge styles -->
    <style name="WMS.Badge">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="WMS.Badge.Success">
        <item name="android:textColor">@color/successText</item>
        <item name="android:background">@color/successBg</item>
    </style>

    <style name="WMS.Badge.Warning">
        <item name="android:textColor">@color/warningText</item>
        <item name="android:background">@color/warningBg</item>
    </style>

    <style name="WMS.Badge.Error">
        <item name="android:textColor">@color/errorText</item>
        <item name="android:background">@color/errorBg</item>
    </style>

    <style name="WMS.Badge.Info">
        <item name="android:textColor">@color/infoText</item>
        <item name="android:background">@color/infoBg</item>
    </style>

</resources>
