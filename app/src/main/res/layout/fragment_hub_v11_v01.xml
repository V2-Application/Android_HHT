<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <TextView
            android:id="@+id/txt_hub_v11_v01_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="V11-V01"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="#e71821"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Plant (read-only, auto-filled from SharedPrefs) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plant"
            android:textStyle="bold"
            android:textColor="#333"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <EditText
            android:id="@+id/txt_hub_v11_v01_werks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:background="#e0e0e0"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="#555"
            android:layout_marginBottom="12dp"
            android:hint="Auto-filled from device"/>

        <!-- HU Number — active scan input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HU"
            android:textStyle="bold"
            android:textColor="#333"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <EditText
            android:id="@+id/txt_hub_v11_v01_hu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Scan or enter HU number"
            android:inputType="textCapCharacters|textNoSuggestions"
            android:imeOptions="actionDone"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <!-- Scanned HU (read-only echo — fills in after HU is scanned/entered) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scanned HU"
            android:textStyle="bold"
            android:textColor="#333"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <EditText
            android:id="@+id/txt_hub_v11_v01_scanned_hu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:background="#e0e0e0"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="#555"
            android:layout_marginBottom="12dp"
            android:hint="—"/>

        <!-- Type — read-only, pre-set to V11 (IV_LGTYP), greyed out like Plant -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type"
            android:textStyle="bold"
            android:textColor="#333"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <EditText
            android:id="@+id/txt_hub_v11_v01_lgtyp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="V11"
            android:enabled="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:background="#e0e0e0"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="#555"
            android:layout_marginBottom="20dp"/>

        <!-- Result Panel — shown after auto-submit returns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SAP Response"
                android:textStyle="bold"
                android:textColor="#555"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/txt_hub_v11_v01_result_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/txt_hub_v11_v01_result_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#222"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
