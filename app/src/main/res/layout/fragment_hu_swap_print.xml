<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- ══ PRINTER SECTION ══════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BLUETOOTH PRINTER"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1B4F72"
                android:letterSpacing="0.08"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <EditText
                    android:id="@+id/txt_hu_swap_printer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Scan or type printer name"
                    android:inputType="textCapCharacters"
                    android:imeOptions="actionDone"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_hu_swap_detect_printer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detect"
                    android:textColor="#fff"
                    android:textSize="12sp"
                    android:background="#1B4F72"
                    android:padding="8dp" />
            </LinearLayout>

            <!-- Printer status indicator badge -->
            <TextView
                android:id="@+id/txt_hu_swap_printer_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● NOT CONNECTED"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B71C1C"
                android:layout_marginBottom="12dp" />

            <!-- ══ HU SCAN SECTION ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SCAN OLD HU BARCODE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1B4F72"
                android:letterSpacing="0.08"
                android:layout_marginBottom="4dp" />

            <!-- Prominent scan field with left accent strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1B4F72"
                android:layout_marginBottom="14dp">

                <!-- Left accent strip (4dp) -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="#F39C12" />

                <EditText
                    android:id="@+id/txt_hu_swap_old_hu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Scan Old HU Barcode"
                    android:inputType="textCapCharacters"
                    android:imeOptions="actionDone"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#AACCEE"
                    android:padding="14dp"
                    android:background="@null"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- ══ COUNTER CARD ══════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <!-- Count row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SESSION COUNT"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/txt_hu_swap_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 HUs"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#1B4F72" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- Last swap pair -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LAST SWAP"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/txt_hu_swap_last_new_hu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1B4F72"
                    android:singleLine="false" />

            </LinearLayout>

            <!-- ══ STATUS CARD ═══════════════════════════════════════════════ -->
            <TextView
                android:id="@+id/txt_hu_swap_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#065f46"
                android:padding="10dp"
                android:background="#E8F5E9"
                android:layout_marginBottom="14dp"
                android:visibility="gone" />

            <!-- ══ ACTION BUTTONS ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_hu_swap_reset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="Reset Session"
                    android:textColor="#fff"
                    android:background="#C0392B" />

                <Button
                    android:id="@+id/btn_hu_swap_back"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="Back"
                    android:textColor="#fff"
                    android:background="#555555" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
