<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.v2retail.dotvik.hub.HubProcessSelectionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="#000"
        android:padding="5dp">

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/hub_inward_hu_grc"
            android:background="#e71821"
            android:text="HU GRC" />

        <!-- HU Stock Review — ZWM_HU_STOCK_REV_RFC | DEV 2026-04-21 -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/hub_inward_hu_stock_review"
            android:background="#e71821"
            android:text="HU Stock Review" />

        <!-- V11-V01 — ZWM_HU_STOCK_REV_RFC with Type pre-set to V11 | DEV 2026-04-22 -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/hub_inward_v11_v01"
            android:background="#e71821"
            android:text="V11-V01" />

        <!-- HUB HU Picking — ZWM_HUB_HU_PICKING_RFC | DEV 2026-04-23 -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/hub_inward_hu_picking"
            android:background="#e71821"
            android:text="HUB HU Picking" />

        <!-- HUB HU Putway — ZWM_HUB_HU_PUTWAY_RFC | DEV 2026-04-23 -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/hub_inward_hu_putway"
            android:background="#e71821"
            android:text="HUB HU Putway" />

        <!-- HUB HU Putaway (batch) — ZWM_HUB_HU_PUTWAY_RFC, LGTYP=V01 | DEV 2026-04-25 -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/hub_inward_hu_putaway"
            android:background="#e71821"
            android:text="HUB HU Putaway" />

    </LinearLayout>
</FrameLayout>
