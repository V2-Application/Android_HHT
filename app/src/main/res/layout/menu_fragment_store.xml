<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STORE OPERATIONS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/retail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Retail" />
            <Button
                android:id="@+id/inbound"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Inbound" />
            <Button
                android:id="@+id/outbound"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Outbound" />
            <Button
                android:id="@+id/stock_take"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Stock Take" />
            <Button
                android:id="@+id/ecomm"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Ecomm" />
            <Button
                android:id="@+id/display_area"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_secondary"
                android:textColor="#fff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Display Area" />
            <Button
                android:id="@+id/reports"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:background="@drawable/btn_muted"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Reports" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
