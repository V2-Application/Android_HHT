<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="#000"
        android:padding="5dp">

        <Button
            android:id="@+id/ptl_grt_crate_picking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="CRATE PICKING"
            android:textColor="#fff" />

        <Button
            android:id="@+id/ptl_grt_palette_putaway"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="PALETTE PUTAWAY"
            android:textColor="#fff" />

        <Button
            android:id="@+id/ptl_grt_palette_receive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="PALETTE RECEIVE"
            android:textColor="#fff" />

        <Button
            android:id="@+id/ptl_grt_floor_hub_wise_crate_tag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="FLOOR - HUB Wise Crate Tag"
            android:textColor="#fff" />

        <Button
            android:id="@+id/ptl_grt_receive_pallet_at_hub_sorting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="Receive Pallet at Hub Sorting"
            android:textColor="#fff" />

        <Button
            android:id="@+id/ptl_grt_hub_sorting_scan_crate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="Hub Sorting-Scan Crate"
            android:textColor="#fff" />

        <Button
            android:id="@+id/ptl_grt_hub_hu_crate_closed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="HUB HU/Crate Closed"
            android:textColor="#fff" />

        <Button
            android:id="@+id/ptl_grt_palette_tag_with_crate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="#e71821"
            android:text="PALLATE Tag With Crate"
            android:textColor="#fff" />

    </LinearLayout>

</FrameLayout>
