<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1F33">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp" android:elevation="4dp">
        <Button android:id="@+id/btnSapBack"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="← Back" android:textSize="12sp" android:textColor="#7B94B5"
            android:background="@drawable/bg_btn_ghost" android:layout_marginEnd="8dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SAP Vendor Creation" android:textColor="#E8EDF5"
                android:textStyle="bold" android:textSize="15sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Level 5 — MDM Team Final Push"
                android:textColor="#F97316" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressSapPush"
        android:layout_width="match_parent" android:layout_height="3dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true" android:progressTint="#22C55E"
        android:visibility="gone"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Vendor summary -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VENDOR SUMMARY" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvSapVendorName"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#E8EDF5" android:textStyle="bold"
                    android:textSize="16sp" android:layout_marginBottom="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Ticket" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvSapTicket" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#3B82F6" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="PAN" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvSapPan" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="GSTIN" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvSapGstin" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Bank" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvSapBank" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="IFSC" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvSapIfsc" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Company / Div" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1.5" android:orientation="horizontal">
                        <TextView android:id="@+id/tvSapCompany" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="#E8EDF5" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" / " android:textColor="#5A6A8A" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvSapDivision" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="#E8EDF5" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Accounts team checklist -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ACCOUNTS TEAM VERIFICATION" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>
                <CheckBox android:id="@+id/cbSapAccBank" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Bank Details Verified *"
                    android:textColor="#E8EDF5" android:textSize="13sp" android:layout_marginBottom="6dp"
                    android:buttonTint="#3B82F6"/>
                <CheckBox android:id="@+id/cbSapAccGst" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="GST Number Verified *"
                    android:textColor="#E8EDF5" android:textSize="13sp" android:layout_marginBottom="6dp"
                    android:buttonTint="#3B82F6"/>
                <CheckBox android:id="@+id/cbSapAccPan" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="PAN &amp; Other Details Verified *"
                    android:textColor="#E8EDF5" android:textSize="13sp"
                    android:buttonTint="#3B82F6"/>
            </LinearLayout>

            <!-- MDM team checklist -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MDM TEAM VERIFICATION" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>
                <CheckBox android:id="@+id/cbSapMdmBank" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Bank Details Checked in SAP *"
                    android:textColor="#E8EDF5" android:textSize="13sp" android:layout_marginBottom="6dp"
                    android:buttonTint="#F97316"/>
                <CheckBox android:id="@+id/cbSapMdmGst" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="GSTIN Validated on GST Portal *"
                    android:textColor="#E8EDF5" android:textSize="13sp" android:layout_marginBottom="6dp"
                    android:buttonTint="#F97316"/>
                <CheckBox android:id="@+id/cbSapMdmPan" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="PAN Verified on IT Portal *"
                    android:textColor="#E8EDF5" android:textSize="13sp" android:layout_marginBottom="6dp"
                    android:buttonTint="#F97316"/>
                <CheckBox android:id="@+id/cbSapMdmDup" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Duplicate Check Done in SAP *"
                    android:textColor="#E8EDF5" android:textSize="13sp"
                    android:buttonTint="#F97316"/>
            </LinearLayout>

            <!-- SAP mapping -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SAP DATA MAPPING" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ACCOUNT GROUP" android:textColor="#5A6A8A" android:textSize="10sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSapAccountGroup"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RECONCILIATION ACCOUNT" android:textColor="#5A6A8A" android:textSize="10sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSapReconAccount"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PAYMENT TERMS (SAP CODE)" android:textColor="#5A6A8A" android:textSize="10sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spSapPaymentTerms"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WITHHOLDING TAX CODE" android:textColor="#5A6A8A" android:textSize="10sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etSapWhtCode"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:textColor="#E8EDF5" android:textColorHint="#5A6A8A"
                    android:hint="e.g. 194C, 194J" android:layout_marginBottom="10dp"
                    android:inputType="textCapCharacters"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PURCHASING ORGANISATION" android:textColor="#5A6A8A" android:textSize="10sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etSapPurchasingOrg"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_field" android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:textColor="#E8EDF5" android:inputType="textCapCharacters"/>
            </LinearLayout>

            <!-- Save + Push -->
            <Button android:id="@+id/btnSapSave"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="💾  Save Checklist" android:textColor="#E8EDF5"
                android:textSize="14sp" android:background="@drawable/bg_btn_outline"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvSapPushHint"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Complete all checklist items to enable SAP push"
                android:textColor="#9E9E9E" android:textSize="12sp"
                android:gravity="center" android:layout_marginBottom="8dp"/>

            <Button android:id="@+id/btnSapPush"
                android:layout_width="match_parent" android:layout_height="60dp"
                android:text="🚀  PUSH TO SAP — CREATE VENDOR"
                android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="15sp"
                android:background="#1B5E20" android:layout_marginBottom="16dp"
                android:enabled="false" android:alpha="0.4"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
