<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Section header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INWARD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <!-- Row 1: GRC + HU Tag -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/grc_putway"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="GRC Putaway"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:background="@color/v2Blue" />

                <Button
                    android:id="@+id/hu_tag"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="HU Tag"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:background="@color/v2Blue" />
            </LinearLayout>

            <!-- Row 2: HU to Pallet + Pallet Receive -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/hu_to_pallet"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="HU to Pallet"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:background="@color/v2Blue" />

                <Button
                    android:id="@+id/pallet_receive"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Pallet Receive"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="13sp"
                    android:background="@color/v2Blue" />
            </LinearLayout>

            <!-- Full-width buttons -->
            <Button
                android:id="@+id/hu_putway"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="HU Putaway in MSA"
                android:textColor="@color/textOnPrimary"
                android:textSize="13sp"
                android:background="@color/v2Blue"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/inward_hu_tag_ext"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Inward HU Tag Ext"
                android:textColor="@color/textOnPrimary"
                android:textSize="13sp"
                android:background="@color/v2Blue"
                android:layout_marginBottom="8dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TVS PAPERLESS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/tvs_paperless_inward"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="TVS Paperless Inward"
                android:textColor="@color/textOnPrimary"
                android:textSize="13sp"
                android:background="@color/v2Blue"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/tvs_paperless_reprint"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="TVS Paperless Re-Print"
                android:textColor="@color/textOnPrimary"
                android:textSize="13sp"
                android:background="@color/v2Blue"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
