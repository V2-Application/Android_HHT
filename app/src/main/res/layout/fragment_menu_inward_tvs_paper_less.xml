<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TODO: Update blank fragment layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="@color/bgPage">
        <LinearLayout
        android:id="@+id/ll_tvs_paperless"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bgPage"
        android:padding="5dp">

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/btn_tvs_paperless_picking"
            android:background="@drawable/btn_secondary"
            android:text="Picking" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/btn_tvs_paperless_picking_confirm"
            android:background="@drawable/btn_secondary"
            android:text="Picking Confirmation" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/btn_tvs_paperless_re_print"
            android:background="@drawable/btn_secondary"
            android:text="Re-Print" />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="#fff"
            android:id="@+id/btn_tvs_paperless_test_print"
            android:background="@drawable/btn_secondary"
            android:text="Test Print" />
    </LinearLayout>
        <LinearLayout
            android:id="@+id/ll_tvs_paperless_live_hu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bgPage"
            android:padding="5dp">

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:id="@+id/btn_tvs_paperless_picking_live_hu"
                android:background="@drawable/btn_secondary"
                android:text="Picking" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:textColor="#fff"
                android:id="@+id/btn_tvs_paperless_re_print_live_hu"
                android:background="@drawable/btn_secondary"
                android:visibility="gone"
                android:text="Re-Print" />
        </LinearLayout>
    </LinearLayout>
    </ScrollView>
</FrameLayout>