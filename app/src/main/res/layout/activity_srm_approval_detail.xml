<?xml version="1.0" encoding="utf-8"?>
<!-- Approval Detail Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/colorPrimary" android:orientation="horizontal"
        android:padding="16dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Application Review" android:textColor="@color/white"
            android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/srm_tv_stage"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@color/statBlueBg"
            android:textColor="@color/colorInfo" android:textSize="11sp" android:textStyle="bold"
            android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp"
            android:text="L1" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Vendor Info Card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/bgCard" android:orientation="vertical" android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VENDOR INFORMATION" android:textColor="@color/textLabel"
                    android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="10dp" />
                <TextView android:id="@+id/srm_tv_vendor_name" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/textPrimary" android:textSize="17sp" android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Info grid -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TICKET" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_ticket" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TYPE" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DIVISION" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_division" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAYMENT TERMS" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_payment_terms" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAN" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_pan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GSTIN" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_gstin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BANK" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_bank" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IFSC" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_ifsc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Documents Card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/bgCard" android:orientation="vertical" android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="UPLOADED DOCUMENTS" android:textColor="@color/textLabel"
                    android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="10dp" />
                <LinearLayout android:id="@+id/srm_ll_docs" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>

            <!-- Checklist Card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/bgCard" android:orientation="vertical" android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="APPROVAL CHECKLIST" android:textColor="@color/textLabel"
                    android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="10dp" />
                <LinearLayout android:id="@+id/srm_ll_checklist" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Action buttons pinned at bottom -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/bgCard" android:orientation="horizontal"
        android:padding="12dp" android:elevation="6dp">
        <Button android:id="@+id/srm_btn_reject"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:background="@color/colorError"
            android:text="REJECT" android:textColor="@color/white"
            android:textSize="13sp" android:textStyle="bold" android:layout_marginEnd="8dp" />
        <Button android:id="@+id/srm_btn_approve"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:background="@color/colorSuccess"
            android:text="APPROVE" android:textColor="@color/white"
            android:textSize="13sp" android:textStyle="bold" android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
