<?xml version="1.0" encoding="utf-8"?>
<!-- MDM SAP Push Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgPage"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/colorPrimary" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SAP Vendor Creation" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/srm_tv_sap_status" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SAP RFC: Checking..." android:textColor="#AAAAAA" android:textSize="11sp" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Vendor Summary -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/bgCard" android:orientation="vertical" android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VENDOR SUMMARY" android:textColor="@color/textLabel"
                    android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="10dp" />
                <TextView android:id="@+id/srm_tv_vendor_name" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/textPrimary" android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TICKET" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_ticket" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TYPE" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAN" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_pan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GSTIN" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_gstin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BANK / ACCOUNT" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_bank" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IFSC / COMP CODE" android:textColor="@color/textLabel" android:textSize="9sp" android:textStyle="bold" />
                        <TextView android:id="@+id/srm_tv_ifsc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/textPrimary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Accounts Team Checklist -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/bgCard" android:orientation="vertical" android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ACCOUNTS TEAM VERIFICATION" android:textColor="@color/colorInfo"
                    android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="10dp" />
                <CheckBox android:id="@+id/srm_cb_acc_bank" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Bank Details Verified *" android:textSize="13sp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                <CheckBox android:id="@+id/srm_cb_acc_gst" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="GST Number Verified *" android:textSize="13sp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                <CheckBox android:id="@+id/srm_cb_acc_pan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PAN &amp; Other Details Verified *" android:textSize="13sp" android:paddingTop="6dp" android:paddingBottom="6dp" />
            </LinearLayout>

            <!-- MDM Team Checklist -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/bgCard" android:orientation="vertical" android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MDM TEAM VERIFICATION" android:textColor="@color/colorWarning"
                    android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="10dp" />
                <CheckBox android:id="@+id/srm_cb_mdm_bank" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Bank Details Checked in SAP *" android:textSize="13sp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                <CheckBox android:id="@+id/srm_cb_mdm_gst" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="GST Validated on GST Portal *" android:textSize="13sp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                <CheckBox android:id="@+id/srm_cb_mdm_pan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PAN Verified on IT Portal *" android:textSize="13sp" android:paddingTop="6dp" android:paddingBottom="6dp" />
                <CheckBox android:id="@+id/srm_cb_mdm_duplicate" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Duplicate Check in SAP *" android:textSize="13sp" android:paddingTop="6dp" android:paddingBottom="6dp" />
            </LinearLayout>

            <!-- SAP Data Mapping -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/bgCard" android:orientation="vertical" android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SAP DATA MAPPING" android:textColor="@color/textLabel"
                    android:textSize="10sp" android:textStyle="bold" android:layout_marginBottom="10dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Account Group" android:textColor="@color/textLabel" android:textSize="10sp" android:layout_marginBottom="4dp" />
                <Spinner android:id="@+id/srm_sp_account_group" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_srm" android:paddingStart="10dp" android:layout_marginBottom="10dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reconciliation Account" android:textColor="@color/textLabel" android:textSize="10sp" android:layout_marginBottom="4dp" />
                <Spinner android:id="@+id/srm_sp_recon_account" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_srm" android:paddingStart="10dp" android:layout_marginBottom="10dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payment Terms (SAP)" android:textColor="@color/textLabel" android:textSize="10sp" android:layout_marginBottom="4dp" />
                <Spinner android:id="@+id/srm_sp_payment_terms" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_input_srm" android:paddingStart="10dp" android:layout_marginBottom="10dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WHT Code" android:textColor="@color/textLabel" android:textSize="10sp" android:layout_marginBottom="4dp" />
                        <EditText android:id="@+id/srm_et_wht_code" android:layout_width="match_parent" android:layout_height="44dp"
                            android:background="@drawable/bg_input_srm" android:hint="194C / 194J"
                            android:paddingStart="10dp" android:textSize="13sp" android:textColor="@color/textPrimary" android:inputType="text" android:singleLine="true" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Purch. Org" android:textColor="@color/textLabel" android:textSize="10sp" android:layout_marginBottom="4dp" />
                        <EditText android:id="@+id/srm_et_purchasing_org" android:layout_width="match_parent" android:layout_height="44dp"
                            android:background="@drawable/bg_input_srm" android:hint="V2RL"
                            android:paddingStart="10dp" android:textSize="13sp" android:textColor="@color/textPrimary" android:inputType="text" android:singleLine="true" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tolerance Group" android:textColor="@color/textLabel" android:textSize="10sp" android:layout_marginBottom="4dp" />
                        <EditText android:id="@+id/srm_et_tolerance_group" android:layout_width="match_parent" android:layout_height="44dp"
                            android:background="@drawable/bg_input_srm" android:hint="V001"
                            android:paddingStart="10dp" android:textSize="13sp" android:textColor="@color/textPrimary" android:inputType="text" android:singleLine="true" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Company Code" android:textColor="@color/textLabel" android:textSize="10sp" android:layout_marginBottom="4dp" />
                        <TextView android:id="@+id/srm_tv_comp_code" android:layout_width="match_parent" android:layout_height="44dp"
                            android:background="@color/bgInput" android:text="—"
                            android:paddingStart="10dp" android:textSize="13sp" android:textColor="@color/textPrimary"
                            android:gravity="center_vertical" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <Button android:id="@+id/srm_btn_save_checklist"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_btn_secondary"
                android:text="SAVE CHECKLIST" android:textColor="@color/textPrimary"
                android:textSize="12sp" android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- SAP Push button pinned at bottom -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/colorSuccessBg" android:orientation="vertical"
        android:padding="16dp" android:elevation="8dp">
        <Button android:id="@+id/srm_btn_push_sap"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@color/colorSuccess"
            android:text="PUSH TO SAP — CREATE VENDOR"
            android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Complete all checklist items to enable"
            android:textColor="@color/textSecondary" android:textSize="11sp"
            android:gravity="center" android:layout_marginTop="6dp" />
    </LinearLayout>

</LinearLayout>
