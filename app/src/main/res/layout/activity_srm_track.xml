<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1F33">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="4dp">
        <TextView android:layout_width="32dp" android:layout_height="32dp"
            android:text="V2" android:textColor="#FFFFFF" android:textStyle="bold"
            android:textSize="13sp" android:gravity="center"
            android:background="@drawable/bg_v2_badge" android:layout_marginEnd="10dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Track Application"
            android:textColor="#E8EDF5" android:textStyle="bold" android:textSize="16sp"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressSrmTrack"
        android:layout_width="match_parent" android:layout_height="3dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true" android:progressTint="#3B82F6"
        android:visibility="gone"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="16dp" android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TICKET NUMBER" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <EditText android:id="@+id/etSrmTrackTicket"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:background="@drawable/bg_field"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:textColor="#E8EDF5" android:textColorHint="#5A6A8A"
                        android:hint="e.g. TKT-2026-10001"
                        android:inputType="textCapCharacters" android:layout_marginEnd="8dp"/>
                    <Button android:id="@+id/btnSrmTrackSearch"
                        android:layout_width="wrap_content" android:layout_height="48dp"
                        android:text="Search" android:textColor="#FFFFFF"
                        android:textStyle="bold" android:background="@drawable/bg_btn_primary"
                        android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/layoutSrmTrackResult"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <!-- Summary card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/bg_card"
                    android:padding="16dp" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="APPLICATION SUMMARY" android:textColor="#5A6A8A"
                        android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Ticket No." android:textColor="#5A6A8A" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvSrmTrackTicket"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#3B82F6"
                                android:textStyle="bold" android:textSize="14sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Submitted" android:textColor="#5A6A8A" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvSrmTrackSubmitted"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#E8EDF5" android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Vendor" android:textColor="#5A6A8A" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvSrmTrackVendor"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#E8EDF5"
                                android:textStyle="bold" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Current Stage" android:textColor="#5A6A8A" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvSrmTrackStatus"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#F59E0B"
                                android:textStyle="bold" android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- SAP Code (shown when approved) -->
                <LinearLayout android:id="@+id/llSrmTrackSapCode"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="#0A2A1A"
                    android:padding="16dp" android:gravity="center"
                    android:layout_marginBottom="12dp" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SAP VENDOR CODE" android:textColor="#5A6A8A"
                        android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tvSrmTrackSapCode"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#22C55E"
                        android:textStyle="bold" android:textSize="28sp" android:letterSpacing="0.08"/>
                </LinearLayout>

                <!-- Pipeline -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="APPROVAL PIPELINE" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
                <LinearLayout android:id="@+id/layoutSrmTrackPipeline"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
