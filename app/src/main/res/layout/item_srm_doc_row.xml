<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="10dp"
    android:gravity="center_vertical" android:layout_marginBottom="4dp">
    <TextView android:id="@+id/tvDocRowIcon"
        android:layout_width="28dp" android:layout_height="wrap_content"
        android:text="📄" android:textSize="18sp" android:layout_marginEnd="10dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvDocRowLabel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Document" android:textColor="#E8EDF5"
            android:textSize="13sp" android:textStyle="bold"/>
    </LinearLayout>
    <TextView android:id="@+id/tvDocRowStatus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="—" android:textSize="12sp" android:textStyle="bold"/>
</LinearLayout>
