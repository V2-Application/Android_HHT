<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0F1F33">

    <!-- Topbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp" android:elevation="4dp">
        <Button android:id="@+id/btnDetailBack"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="← Back" android:textSize="12sp" android:textColor="#7B94B5"
            android:background="@drawable/bg_btn_ghost" android:layout_marginEnd="8dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Application Review" android:textColor="#E8EDF5"
                android:textStyle="bold" android:textSize="15sp"/>
            <TextView android:id="@+id/tvDetailCurrentStage"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Loading…" android:textColor="#F59E0B" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressDetail"
        android:layout_width="match_parent" android:layout_height="3dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true" android:progressTint="#3B82F6"
        android:visibility="visible"/>

    <ScrollView android:id="@+id/scrollDetail"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Stage message -->
            <TextView android:id="@+id/tvDetailStageMsg"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#0A1E3A" android:padding="12dp"
                android:textColor="#93C5FD" android:textSize="13sp"
                android:layout_marginBottom="12dp" android:visibility="gone"/>

            <!-- Vendor info grid -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VENDOR INFORMATION" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ticket" android:textColor="#5A6A8A" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvDetailTicket" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="#3B82F6" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Type" android:textColor="#5A6A8A" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvDetailType" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="#E8EDF5" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:id="@+id/tvDetailVendorName" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="—"
                    android:textColor="#E8EDF5" android:textStyle="bold"
                    android:textSize="16sp" android:layout_marginBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#1C2438" android:layout_marginBottom="10dp"/>
                <!-- Detail rows -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Division" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailDivision" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Company Code" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailCompany" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="PAN" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailPan" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="GSTIN" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailGstin" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Bank" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailBank" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="IFSC" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailIfsc" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Mobile" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailMobile" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Location" android:textColor="#5A6A8A" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvDetailCity" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1.5"
                        android:text="—" android:textColor="#E8EDF5" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Documents -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="UPLOADED DOCUMENTS" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
                <LinearLayout android:id="@+id/llDetailDocs"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Checklist -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="APPROVAL CHECKLIST" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
                <LinearLayout android:id="@+id/llDetailChecklist"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Approve/Reject bar -->
            <LinearLayout android:id="@+id/layoutDetailApproveBar"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp"
                android:visibility="gone">
                <Button android:id="@+id/btnDetailReject"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:text="✕  Reject"
                    android:textColor="#FFFFFF" android:textStyle="bold"
                    android:background="#C62828" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnDetailApprove"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1.4" android:text="✓  Approve &amp; Forward"
                    android:textColor="#FFFFFF" android:textStyle="bold"
                    android:background="#2E7D32"/>
            </LinearLayout>

            <!-- Approval trail -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="APPROVAL TRAIL" android:textColor="#5A6A8A"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
                <LinearLayout android:id="@+id/llDetailTrail"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
