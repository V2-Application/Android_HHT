<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TODO: Update blank fragment layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"
        android:background="@color/bgPage"
        android:padding="5dp">

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:id="@+id/create_scan"
            android:background="@color/v2Blue"
            android:text="Crate Scan" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            >
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Putway"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:textColor="@color/textOnPrimary"
                android:id="@+id/putway"
                android:background="@color/v2Blue" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ecom Putway"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:textColor="@color/textOnPrimary"
                android:textAllCaps="false"
                android:id="@+id/ecom_putway"
                android:background="@color/v2Blue" />

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="GRC Putway"
                android:layout_margin="5dp"
                android:textColor="@color/textOnPrimary"
                android:visibility="visible"
                android:id="@+id/grc_putway"
                android:layout_weight="1"
                android:background="@color/v2Blue" />

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Stored Stock"
                android:textAllCaps="false"
                android:layout_margin="5dp"
                android:textColor="@color/textOnPrimary"
                android:layout_weight="1"
                android:id="@+id/stored_stock"
                android:background="@color/v2Blue" />


        </LinearLayout>

        <Button
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="GRT Scanning (01)"
            android:textAllCaps="false"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:id="@+id/grt_scanning01"
            android:background="@color/v2Blue" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="GRT Putway (03)"
            android:textAllCaps="false"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:id="@+id/grt_putway03"
            android:background="@color/v2Blue" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="GRT HU Putway in Bin"
            android:textAllCaps="false"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:id="@+id/grt_putway_hu_in_bin"
            android:background="@color/v2Blue" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="HU Tag EXT"
            android:textAllCaps="false"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:id="@+id/inward_hu_tag_ext"
            android:background="@color/v2Blue" />


        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bin Consolidation"
            android:id="@+id/bin_consolidation"
            android:layout_margin="5dp"
            android:textColor="@color/textOnPrimary"
            android:background="@color/v2Blue" />

    </LinearLayout>

</FrameLayout>