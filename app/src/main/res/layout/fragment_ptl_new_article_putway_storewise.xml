<?xml version="1.0" encoding="utf-8"?>
<!--
    PTL — Article Putway Store Wise.
    Reference UI: label column (11sp bold) + stacked bordered value column (30dp min height),
    groups separated by vertical space, generous scroll padding above BACK/SUBMIT footer.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">
    <ScrollView
        android:id="@+id/ptl_apsw_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/ptl_apsw_footer"
        android:layout_alignParentTop="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- ═════ Group 1 — FLR Station / HUB ═════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="top"
                android:orientation="horizontal"
                android:weightSum="12">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:orientation="vertical"
                    android:paddingEnd="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Scan FLR STATION"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Station"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="HUB"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_scan_station"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/apsw_putway_cell_editable"
                        android:gravity="center"
                        android:hint="Scan Station"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:singleLine="true"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textSecondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_station"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:background="@drawable/apsw_putway_cell_readonly"
                        android:enabled="false"
                        android:gravity="center"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="@color/textPrimary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_hub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:background="@drawable/apsw_putway_cell_readonly"
                        android:enabled="false"
                        android:gravity="center"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="@color/textPrimary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═════ Group 2 — Crate ═════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:baselineAligned="false"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="top"
                android:orientation="horizontal"
                android:weightSum="12">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:orientation="vertical"
                    android:paddingEnd="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Scan Crate"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Crate"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_scan_crate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/apsw_putway_cell_editable"
                        android:gravity="center"
                        android:hint="Scan Crate"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:singleLine="true"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textSecondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_crate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:background="@drawable/apsw_putway_cell_readonly"
                        android:enabled="false"
                        android:gravity="center"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="@color/textPrimary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═════ Group 3 — Article / Store ═════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:baselineAligned="false"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="top"
                android:orientation="horizontal"
                android:weightSum="12">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:orientation="vertical"
                    android:paddingEnd="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Scan Article"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Article"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Proposed Store"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Store Floor"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_scan_article"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/apsw_putway_cell_editable"
                        android:gravity="center"
                        android:hint="Scan Article"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:singleLine="true"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textSecondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_article"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:background="@drawable/apsw_putway_cell_readonly"
                        android:enabled="false"
                        android:gravity="center"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="@color/textPrimary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_proposed_store"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:background="@drawable/apsw_putway_cell_readonly"
                        android:enabled="false"
                        android:gravity="center"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_store_floor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:background="@drawable/apsw_putway_cell_readonly"
                        android:enabled="false"
                        android:gravity="center"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═════ Group 4 — HU ═════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:baselineAligned="false"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="top"
                android:orientation="horizontal"
                android:weightSum="12">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:orientation="vertical"
                    android:paddingEnd="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="Scan HU"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|start"
                        android:minHeight="30dp"
                        android:text="HU"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_scan_hu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/apsw_putway_cell_editable"
                        android:gravity="center"
                        android:hint="Scan Hu"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:singleLine="true"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textSecondary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/txt_ptl_new_article_putway_storewise_hu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:background="@drawable/apsw_putway_cell_readonly"
                        android:enabled="false"
                        android:gravity="center"
                        android:minHeight="30dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="@color/textPrimary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═════ Group 5 — Pending Qty (green border) ═════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                android:weightSum="12">
                <!-- android:visibility="gone" -->

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:gravity="center_vertical|start"
                    android:minHeight="30dp"
                    android:paddingEnd="10dp"
                    android:text="Pending Qty"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/txt_ptl_new_article_putway_storewise_pending_qty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:background="@drawable/apsw_putway_cell_pending"
                    android:enabled="false"
                    android:gravity="center"
                    android:minHeight="30dp"
                    android:paddingStart="8dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="3dp"
                    android:textColor="@color/textPrimary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/ptl_apsw_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="start"
        android:orientation="horizontal"
        android:padding="5dp">

        <Button
            android:id="@+id/btn_ptl_new_article_putway_storewise_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:background="#e71821"
            android:minWidth="120dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="RESET"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</RelativeLayout>
